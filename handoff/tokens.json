  "effect": {
    "candle-glow":  { "value": "radial-gradient(circle, #E5A95A88, transparent 60%)", "description": "Используется с blur и mix-blend-mode: screen" },
    "vignette":     { "value": "radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.6) 100%)" },
    "film-grain":   { "value": "url('/textures/grain.png')", "description": "PNG 256x256, opacity 0.18, mix-blend-mode: overlay" }
  }
