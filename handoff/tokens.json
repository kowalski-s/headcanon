      "deep": { "value": "#06030C", "description": "Watch mode hero (на тон ниже)" }
    },
    "surface": {
      "soft":   { "value": "rgba(245,239,224,0.04)", "description": "Карточки на фоне ленты" },
      "raised": { "value": "rgba(245,239,224,0.06)", "description": "Sticky-CTA, NEXT-блок" }
    },
    "ink": {
      "base":  { "value": "#F5EFE0", "description": "Основная копия и заголовки" },
      "dim":   { "value": "#A89BB5", "description": "Метаданные, secondary" },
      "faint": { "value": "#6E6478", "description": "Disabled, tertiary" }
    },
    "accent": {
      "amber":  { "value": "#E5A95A", "description": "Primary CTA, drop cap, свечной свет" },
